# iMessage Monterey Plugin Configuration
# Copy this file to .env and fill in your values

# Required: OpenClaw Gateway Token
# Get this from your OpenClaw Gateway configuration
OPENCLAW_GATEWAY_TOKEN=your_gateway_token_here

# Optional: OpenClaw Gateway Host
# Default: 127.0.0.1
# OPENCLAW_GATEWAY_HOST=127.0.0.1

# Optional: OpenClaw Gateway Port
# Default: 18789
# OPENCLAW_GATEWAY_PORT=18789

# Optional: OpenClaw Model
# Default: zai/glm-5
# OPENCLAW_MODEL=zai/glm-5

# Optional: iMessage Poll Limit
# Maximum messages to fetch per poll cycle. Default: 100
# IMESSAGE_POLL_LIMIT=100

# Optional: Custom iMessage Helper Path
# Only set if you installed the helper in a non-standard location
# Default: ~/Applications/IMessageHelper.app/Contents/MacOS/imessage-helper
# IMESSAGE_HELPER_PATH=/Applications/IMessageHelper.app/Contents/MacOS/imessage-helper